// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())

  activity UserActivity? @relation  
  teams               TeamMember[]
  accounts            Account[]
  sessions            Session[]
  onboarding          UserOnboarding?
  progress            UserProgress[]
  notifications       Notification[]
  projectApplications ProjectApplication[]
  communityGroups     CommunityGroup[]
  communityMembers    CommunityMember[]
  communityMessages   CommunityMessage[]
  messageReceipts     MessageReceipt[]
  messageReactions    MessageReaction[]
  preferences         UserPreferences?
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  createdBy   String
  status      String   @default("OPEN")
  difficulty  String   @default("Beginner")
  techStack   String[] @default([])
  lookingFor  String?
  type        String   @default("team")
  maxMembers  Int? 
  projectUrl  String?
  repoUrl     String?

  createdAt   DateTime @default(now())

  tasks             Task[]
  teams             TeamMember[]
  applicants        ProjectApplication[]
  communityGroupId  String?      @unique
  communityGroup    CommunityGroup? @relation(fields: [communityGroupId], references: [id])

}

model ProjectApplication {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}


model TeamMember {
  id        String @id @default(uuid())
  userId    String
  projectId String
  role      String

  user User @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String
  projectId   String
  assignedTo  String
  deadline    DateTime
  status      String   @default("TODO")

  project Project @relation(fields: [projectId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserOnboarding {
  id          String   @id @default(uuid())
  userId      String   @unique
  skills      String[]
  goal        String
  pathId      String
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UserProgress {
  id         String   @id @default(uuid())
  userId     String
  pathId     String
  moduleIndex Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, pathId, moduleIndex])
}

model ModuleContent {
  id          String   @id @default(uuid())
  pathId      String
  moduleIndex Int
  sections    Json
  
  @@unique([pathId, moduleIndex])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model JobApplication {
  id         String   @id @default(uuid())
  name       String
  email      String
  role       String
  experience String
  why        String
  github     String?
  portfolio  String?
  resumeUrl  String?
  agreed     Boolean
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UserActivity {
  id                  String   @id @default(uuid())
  userId              String   @unique
  lastSeenProjectsAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CommunityGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())

  members  CommunityMember[]
  messages CommunityMessage[]
  user     User @relation(fields: [createdBy], references: [id])
   project Project?
}

model MessageReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model CommunityMessage {
  id          String   @id @default(uuid())
  groupId     String
  userId      String
  content     String?  // ← make optional (media messages may have no text)
  mediaUrl    String?
  mediaType   String?  // "image" | "video"
  createdAt   DateTime @default(now())

  group     CommunityGroup     @relation(fields: [groupId], references: [id])
  user      User               @relation(fields: [userId], references: [id])
  receipts  MessageReceipt[]
  reactions MessageReaction[]
}

model CommunityMember {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  role      String   @default("MEMBER")
  muted     Boolean  @default(false)
  pinned    Boolean  @default(false)
  joinedAt  DateTime @default(now())

  group CommunityGroup @relation(fields: [groupId], references: [id])
  user  User           @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model UserPreferences {
  id         String   @id @default(uuid())
  userId     String   @unique
  prefTechs  String[] @default([])
  prefTopics String[] @default([])

  user User @relation(fields: [userId], references: [id])
}