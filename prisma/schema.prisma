// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())

  activity            UserActivity?        @relation
  teams               TeamMember[]
  accounts            Account[]
  sessions            Session[]
  onboarding          UserOnboarding?
  progress            UserProgress[]
  notifications       Notification[]
  projectApplications ProjectApplication[]
  communityGroups     CommunityGroup[]
  communityMembers    CommunityMember[]
  communityMessages   CommunityMessage[]
  messageReceipts     MessageReceipt[]
  messageReactions    MessageReaction[]
  preferences         UserPreferences?
  createdProjects     Project[]
  assignedTasks       ProjectTask[]
}

model Project {
  id                String   @id @default(uuid())
  title             String
  description       String
  createdBy         String
  status            String   @default("OPEN")
  difficulty        String   @default("Beginner")
  techStack         String[] @default([])
  projectType       String?
  domain            String?
  buildGoal         String?
  timeToComplete    String?
  complexityType    String[] @default([])
  featuresIncluded  String[] @default([])
  collaborationType String   @default("team")
  monetization      String?
  lookingFor        String?
  maxMembers        Int?
  projectUrl        String?
  repoUrl           String?
  communityGroupId  String?  @unique
  createdAt         DateTime @default(now())

  teams          TeamMember[]
  milestones     Milestone[]
  tasks          ProjectTask[]
  applicants     ProjectApplication[]
  communityGroup CommunityGroup?      @relation(fields: [communityGroupId], references: [id])
  user           User                 @relation(fields: [createdBy], references: [id])
}

model ProjectApplication {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model TeamMember {
  id        String @id @default(uuid())
  userId    String
  projectId String
  role      String

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserOnboarding {
  id          String   @id @default(uuid())
  userId      String   @unique
  skills      String[]
  goal        String
  pathId      String
  completedAt DateTime @default(now())

  user           User   @relation(fields: [userId], references: [id])
  readinessScore Float  @default(0)
  userCategory   String @default("BEGINNER") // BEGINNER | INTERMEDIATE | BUILDER
}

model UserProgress {
  id          String   @id @default(uuid())
  userId      String
  pathId      String
  moduleIndex Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, pathId, moduleIndex])
}

model ModuleContent {
  id          String @id @default(uuid())
  pathId      String
  moduleIndex Int
  sections    Json

  @@unique([pathId, moduleIndex])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model JobApplication {
  id         String   @id @default(uuid())
  name       String
  email      String
  role       String
  experience String
  why        String
  github     String?
  portfolio  String?
  resumeUrl  String?
  agreed     Boolean
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UserActivity {
  id                 String   @id @default(uuid())
  userId             String   @unique
  lastSeenProjectsAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum MemberStatus {
  PENDING
  ACTIVE
  REJECTED
  LEFT
}

enum MemberRole {
  ADMIN
  MEMBER
}

model CommunityGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdBy   String
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())

  members  CommunityMember[]
  messages CommunityMessage[]
  user     User               @relation(fields: [createdBy], references: [id])
  project  Project?
}

model MessageReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model CommunityMessage {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  content   String?
  mediaUrl  String?
  mediaType String?
  createdAt DateTime @default(now())

  group     CommunityGroup    @relation(fields: [groupId], references: [id])
  user      User              @relation(fields: [userId], references: [id])
  receipts  MessageReceipt[]
  reactions MessageReaction[]
}

model CommunityMember {
  id       String         @id @default(uuid())
  groupId  String
  userId   String
  role     MemberRole     @default(MEMBER)
  muted    Boolean        @default(false)
  pinned   Boolean        @default(false)
  status   MemberStatus   @default(PENDING) // PENDING | ACTIVE | REJECTED | LEFT
  joinedAt DateTime       @default(now())

  group CommunityGroup    @relation(fields: [groupId], references: [id])
  user  User              @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model UserPreferences {
  id         String   @id @default(uuid())
  userId     String   @unique
  prefTechs  String[] @default([])
  prefTopics String[] @default([])

  user User @relation(fields: [userId], references: [id])
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]
}

model ProjectTask {
  id          String    @id @default(uuid())
  projectId   String
  milestoneId String?
  assignedTo  String?
  title       String
  description String?
  status      String    @default("TODO") // TODO | IN_PROGRESS | REVIEW | DONE
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  assignee  User?      @relation(fields: [assignedTo], references: [id])
}
